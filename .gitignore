# .gitignore - Ignorar imágenes y artefactos comunes

# Ignorar carpetas de imágenes del proyecto
imgs/
proyecto_extraer_img_pdf/
proyecto_extraer_img_pdf/imgs/

# Extensiones de imagen
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.heic

# Artefactos comunes de Python (opcionales)
__pycache__/
*.py[cod]
*.pyo
venv/
.env
