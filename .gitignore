# .gitignore - Ignorar archivos y carpetas innecesarios

# ========== Carpetas de Imágenes ==========
imgs/
output/
proyecto_extraer_img_pdf/imgs/

# ========== Extensiones de Imagen ==========
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.heic

# ========== Artefactos de Python ==========
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd
*.so
.Python
*.egg
*.egg-info/
dist/
build/

# ========== Entornos Virtuales ==========
venv/
env/
ENV/
.venv

# ========== IDE y Editores ==========
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.vim/
*.sublime-settings

# ========== Sistema Operativo ==========
.DS_Store
Thumbs.db
.env

# ========== Logs ==========
logs/
*.log

# ========== Compilados ==========
*.o
*.a
*.exe
*.dll
*.so

# ========== Directorios de Build ==========
build/
dist/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# ========== Archivos Temporales ==========
*.tmp
*.temp
*.bak
*~
